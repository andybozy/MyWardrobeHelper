{
  "openapi": "3.1.0",
  "info": {
    "title": "MyWardrobeHelper API",
    "version": "0.1.0",
    "description": "Local-first wardrobe management API foundation for health, items, media, locations, movement history, trips, and physical tag resolution."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787/api/v1",
      "description": "Default local development server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Read API health",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "API and shared service layer are reachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server-info": {
      "get": {
        "summary": "Read server runtime info",
        "operationId": "getServerInfo",
        "responses": {
          "200": {
            "description": "Current runtime URLs and data paths",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "summary": "List items",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "Current wardrobe items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemsListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create an item",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "get": {
        "summary": "Get an item",
        "operationId": "getItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update an item",
        "operationId": "updateItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/move": {
      "post": {
        "summary": "Move an item and record movement history",
        "operationId": "moveItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorded movement",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movement"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/movements": {
      "get": {
        "summary": "List item movement history",
        "operationId": "listItemMovements",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movement history for the requested item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MovementsListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/media": {
      "get": {
        "summary": "List media for one item",
        "operationId": "listItemMedia",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Media metadata for the requested item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemMediaListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Upload media for one item",
        "operationId": "uploadItemMedia",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "caption": {
                    "type": "string"
                  },
                  "file": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created media records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemMediaListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid multipart request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/locations": {
      "get": {
        "summary": "List locations",
        "operationId": "listLocations",
        "responses": {
          "200": {
            "description": "Current storage locations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationsListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a location",
        "operationId": "createLocation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLocationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created location",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/locations/{id}": {
      "get": {
        "summary": "Get a location",
        "operationId": "getLocation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "404": {
            "description": "Location not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/trips": {
      "get": {
        "summary": "List trips",
        "operationId": "listTrips",
        "responses": {
          "200": {
            "description": "Current trip records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripsListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a trip",
        "operationId": "createTrip",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTripRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created trip",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Trip"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/trips/{id}": {
      "get": {
        "summary": "Get a trip",
        "operationId": "getTrip",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Trip found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Trip" }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update a trip",
        "operationId": "updateTrip",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchTripRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated trip",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Trip" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/trips/{id}/items": {
      "get": {
        "summary": "List trip packing entries",
        "operationId": "listTripItems",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Trip packing entries",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripItemsListResponse" }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add an item to a trip packing list",
        "operationId": "addTripItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTripItemRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created trip item",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripItem" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/trips/{id}/items/{trip_item_id}": {
      "patch": {
        "summary": "Update a trip packing entry",
        "operationId": "updateTripItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "trip_item_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PatchTripItemRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated trip item",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TripItem" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Remove a trip packing entry",
        "operationId": "deleteTripItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "trip_item_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": {
            "description": "Trip item removed"
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/tags": {
      "get": {
        "summary": "List physical tags",
        "operationId": "listTags",
        "responses": {
          "200": {
            "description": "Current physical tag records",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PhysicalTagsListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Register a physical tag",
        "operationId": "createTag",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePhysicalTagRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created physical tag",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PhysicalTag" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/tags/{id}": {
      "get": {
        "summary": "Get a physical tag",
        "operationId": "getTag",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Physical tag found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PhysicalTag" }
              }
            }
          },
          "404": {
            "description": "Tag not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/tags/resolve": {
      "post": {
        "summary": "Resolve a physical tag to its bound entity",
        "operationId": "resolveTag",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResolvePhysicalTagRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved physical tag",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResolvedPhysicalTagResponse" }
              }
            }
          },
          "404": {
            "description": "Tag not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "item_count", "location_count", "trip_count"],
        "properties": {
          "status": { "type": "string" },
          "item_count": { "type": "integer" },
          "location_count": { "type": "integer" },
          "trip_count": { "type": "integer" }
        }
      },
      "ServerInfoResponse": {
        "type": "object",
        "required": ["application", "version", "bind_url", "local_url", "data_dir", "database_file"],
        "properties": {
          "application": { "type": "string" },
          "version": { "type": "string" },
          "bind_url": { "type": "string" },
          "local_url": { "type": "string" },
          "lan_url": { "type": ["string", "null"] },
          "data_dir": { "type": "string" },
          "database_file": { "type": "string" }
        }
      },
      "ItemsListResponse": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Item" }
          }
        }
      },
      "ItemMediaListResponse": {
        "type": "object",
        "required": ["media"],
        "properties": {
          "media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemMedia"
            }
          }
        }
      },
      "MovementsListResponse": {
        "type": "object",
        "required": ["movements"],
        "properties": {
          "movements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Movement"
            }
          }
        }
      },
      "LocationsListResponse": {
        "type": "object",
        "required": ["locations"],
        "properties": {
          "locations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Location" }
          }
        }
      },
      "TripsListResponse": {
        "type": "object",
        "required": ["trips"],
        "properties": {
          "trips": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Trip" }
          }
        }
      },
      "TripItemsListResponse": {
        "type": "object",
        "required": ["trip_items"],
        "properties": {
          "trip_items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TripItem" }
          }
        }
      },
      "PhysicalTagsListResponse": {
        "type": "object",
        "required": ["tags"],
        "properties": {
          "tags": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PhysicalTag" }
          }
        }
      },
      "CreateItemRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": ["string", "null"] },
          "subcategory": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "size": { "type": ["string", "null"] },
          "color_primary": { "type": ["string", "null"] },
          "color_secondary": { "type": ["string", "null"] },
          "material": { "type": ["string", "null"] },
          "season": { "type": ["string", "null"] },
          "formality": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "current_location_id": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "PatchItemRequest": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "category": { "type": ["string", "null"] },
          "subcategory": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
