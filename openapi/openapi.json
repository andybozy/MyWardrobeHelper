{
  "openapi": "3.1.0",
  "info": {
    "title": "MyWardrobeHelper API",
    "version": "0.1.0",
    "description": "Local-first wardrobe management API foundation for health, items, media, locations, and movement history."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8787/api/v1",
      "description": "Default local development server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Read API health",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "API and shared service layer are reachable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/server-info": {
      "get": {
        "summary": "Read server runtime info",
        "operationId": "getServerInfo",
        "responses": {
          "200": {
            "description": "Current runtime URLs and data paths",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "summary": "List items",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "Current wardrobe items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemsListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create an item",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}": {
      "get": {
        "summary": "Get an item",
        "operationId": "getItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Item found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update an item",
        "operationId": "updateItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/move": {
      "post": {
        "summary": "Move an item and record movement history",
        "operationId": "moveItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveItemRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recorded movement",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movement"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/movements": {
      "get": {
        "summary": "List item movement history",
        "operationId": "listItemMovements",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movement history for the requested item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MovementsListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/items/{id}/media": {
      "get": {
        "summary": "List media for one item",
        "operationId": "listItemMedia",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Media metadata for the requested item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemMediaListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Upload media for one item",
        "operationId": "uploadItemMedia",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "caption": {
                    "type": "string"
                  },
                  "file": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created media records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemMediaListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid multipart request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/locations": {
      "get": {
        "summary": "List locations",
        "operationId": "listLocations",
        "responses": {
          "200": {
            "description": "Current storage locations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LocationsListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a location",
        "operationId": "createLocation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLocationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created location",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/locations/{id}": {
      "get": {
        "summary": "Get a location",
        "operationId": "getLocation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "404": {
            "description": "Location not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "item_count", "location_count", "trip_count"],
        "properties": {
          "status": { "type": "string" },
          "item_count": { "type": "integer" },
          "location_count": { "type": "integer" },
          "trip_count": { "type": "integer" }
        }
      },
      "ServerInfoResponse": {
        "type": "object",
        "required": ["application", "version", "bind_url", "local_url", "data_dir", "database_file"],
        "properties": {
          "application": { "type": "string" },
          "version": { "type": "string" },
          "bind_url": { "type": "string" },
          "local_url": { "type": "string" },
          "lan_url": { "type": ["string", "null"] },
          "data_dir": { "type": "string" },
          "database_file": { "type": "string" }
        }
      },
      "ItemsListResponse": {
        "type": "object",
        "required": ["items"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Item" }
          }
        }
      },
      "ItemMediaListResponse": {
        "type": "object",
        "required": ["media"],
        "properties": {
          "media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemMedia"
            }
          }
        }
      },
      "MovementsListResponse": {
        "type": "object",
        "required": ["movements"],
        "properties": {
          "movements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Movement"
            }
          }
        }
      },
      "LocationsListResponse": {
        "type": "object",
        "required": ["locations"],
        "properties": {
          "locations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Location" }
          }
        }
      },
      "CreateItemRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": ["string", "null"] },
          "subcategory": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "size": { "type": ["string", "null"] },
          "color_primary": { "type": ["string", "null"] },
          "color_secondary": { "type": ["string", "null"] },
          "material": { "type": ["string", "null"] },
          "season": { "type": ["string", "null"] },
          "formality": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "current_location_id": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "PatchItemRequest": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "category": { "type": ["string", "null"] },
          "subcategory": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "size": { "type": ["string", "null"] },
          "color_primary": { "type": ["string", "null"] },
          "color_secondary": { "type": ["string", "null"] },
          "material": { "type": ["string", "null"] },
          "season": { "type": ["string", "null"] },
          "formality": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "MoveItemRequest": {
        "type": "object",
        "properties": {
          "to_location_id": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "CreateLocationRequest": {
        "type": "object",
        "required": ["name", "location_type"],
        "properties": {
          "name": { "type": "string" },
          "location_type": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      },
      "Item": {
        "type": "object",
        "required": ["id", "name", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": ["string", "null"] },
          "subcategory": { "type": ["string", "null"] },
          "brand": { "type": ["string", "null"] },
          "size": { "type": ["string", "null"] },
          "color_primary": { "type": ["string", "null"] },
          "color_secondary": { "type": ["string", "null"] },
          "material": { "type": ["string", "null"] },
          "season": { "type": ["string", "null"] },
          "formality": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "current_location_id": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "Location": {
        "type": "object",
        "required": ["id", "name", "location_type", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "location_type": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      },
      "ItemMedia": {
        "type": "object",
        "required": [
          "id",
          "item_id",
          "media_kind",
          "relative_file_path",
          "original_filename",
          "mime_type",
          "file_size_bytes",
          "sort_order",
          "created_at"
        ],
        "properties": {
          "id": { "type": "string" },
          "item_id": { "type": "string" },
          "media_kind": { "type": "string" },
          "relative_file_path": { "type": "string" },
          "original_filename": { "type": "string" },
          "mime_type": { "type": "string" },
          "file_size_bytes": { "type": "integer" },
          "duration_ms": { "type": ["integer", "null"] },
          "width": { "type": ["integer", "null"] },
          "height": { "type": ["integer", "null"] },
          "caption": { "type": ["string", "null"] },
          "sort_order": { "type": "integer" },
          "created_at": { "type": "string" }
        }
      },
      "Movement": {
        "type": "object",
        "required": ["id", "item_id", "moved_at"],
        "properties": {
          "id": { "type": "string" },
          "item_id": { "type": "string" },
          "from_location_id": { "type": ["string", "null"] },
          "to_location_id": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] },
          "moved_at": { "type": "string" }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": {}
            }
          }
        }
      }
    }
  }
}
